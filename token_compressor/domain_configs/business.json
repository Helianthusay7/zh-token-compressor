{
  "drop_phrases": ["为进一步", "切实", "有效"],
  "replacements": {
    "日常业务": "业务",
    "现有基础框架": "既有框架",
    "现有流程效率": "流程效率",
    "人工重复操作": "人工重复",
    "数据统一管理": "数据统管",
    "可视化展示能力": "可视化能力",
    "完整可用的业务模块": "业务模块"
  },
  "keep_words": ["落地", "流程", "业务", "模块"],
  "domain_terms": ["业务", "线上化", "落地", "流程", "可视化", "模块", "项目", "效率"],
  "template_rules": [
    {
      "pattern": "为满足(.{1,40}?)，优化(.{1,40}?)，减少(.{1,40}?)，提升(.{1,50}?)，现启动(.{1,30}?)，依托(.{1,40}?)搭建(.{1,40}?)。",
      "replacement": "为满足\\1，现启动\\5，基于\\6开发\\7，优化\\2，减少\\3，提升\\4。",
      "label": "业务项目说明模板"
    }
  ]
}
