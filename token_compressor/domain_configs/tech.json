{
  "drop_phrases": ["当前来看", "从技术角度来看"],
  "replacements": {
    "应用程序接口": "API",
    "数据库": "DB",
    "数据库连接": "DB连接",
    "响应时间": "延迟",
    "吞吐能力": "吞吐",
    "进行部署": "部署",
    "错误代码": "错误码"
  },
  "keep_words": ["API", "QPS", "SQL", "HTTP", "HTTPS", "DB", "ID", "错误码", "延迟"],
  "domain_terms": ["API", "接口", "数据库", "服务", "延迟", "吞吐", "QPS", "缓存", "部署", "错误码"],
  "template_rules": [
    {
      "pattern": "由于(.{1,40}?)导致(.{1,50}?)，因此需要(.{1,60})",
      "replacement": "因\\1导致\\2，需\\3",
      "label": "技术因果处理模板"
    }
  ]
}
